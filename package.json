{
  "name": "dugnadapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose -p dugnadapp-shared up -d db",
    "db:down": "docker compose -p dugnadapp-shared down",
    "db:logs": "docker compose -p dugnadapp-shared logs -f db",
    "db:migrate": "tsx scripts/agent-prisma.ts migrate-dev",
    "db:migrate:deploy": "tsx scripts/agent-prisma.ts migrate-deploy",
    "db:seed": "tsx scripts/agent-prisma.ts seed",
    "db:studio": "tsx scripts/agent-prisma.ts studio",
    "agent:init": "tsx scripts/agent-worktree.ts init",
    "agent:destroy": "tsx scripts/agent-worktree.ts destroy",
    "agent:dev": "tsx scripts/agent-worktree.ts dev",
    "agent:info": "tsx scripts/agent-worktree.ts info"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pg": "^8.20.0",
    "prisma": "^6.17.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
